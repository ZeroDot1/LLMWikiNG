{
  "name": "llmwikig-frontend",
  "version": "3.0.0",
  "private": true,
  "description": "Frontend-Build-Pipeline für LLMWikiNG (Tailwind CSS v4, Mobile First, Dark Mode).",
  "scripts": {
    "build": "npx @tailwindcss/cli -i ./src/css/input.css -o ../static/css/tailwind-build.css --minify",
    "watch": "npx @tailwindcss/cli -i ./src/css/input.css -o ../static/css/tailwind-build.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^4.0.0",
    "@tailwindcss/cli": "^4.0.0"
  }
}
